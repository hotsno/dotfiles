# This config file will use environment variables such as $BROWSER and $TERMINAL.

# Refresh rate
exec --no-startup-id xrandr --output DP-2 --mode 1920x1080 --rate 144

# Wallpaper set
exec --no-startup-id feh --bg-scale ~/Pictures/Wallpapers/Vaporwave.jpg

# Polybar
exec --no-startup-id bash ~/.config/polybar/launch.sh --hack

# Autotiling
exec_always --no-startup-id autotiling

# Picom
exec_always --no-startup-id picom -b

# Alt Tab
exec_always --no-startup-id alttab

#
# #---Basic Definitions---# #
# smart_gaps on
smart_borders on
set $inner_gaps 15
set $outer_gaps 0
set $term --no-startup-id	 alacritty
set $mod Mod4
set $alt Mod1
set $shutdown sudo -A shutdown -h now
set $reboot sudo -A reboot
set $lock i3lock
set $suspend sudo systemctl suspend
set $hibernate sudo -A systemctl hibernate

# Use Mouse+$mod to drag floating windows
floating_modifier $mod

# #---Gaps---# #
for_window [class="^.*"] border pixel 2
gaps inner $inner_gaps
gaps outer $outer_gaps

# #---Basic Bindings---# #
bindsym $mod+Return         exec --no-startup-id alacritty

bindsym $mod+Escape         exec --no-startup-id dm-tool switch-to-greeter

bindsym $mod+Shift+Escape   exec --no-startup-id $hibernate

# #---Letter Key Bindings---# #

# a
bindsym $mod+a              exec thunar ~/Videos/Anime

# b
bindsym $mod+b              exec --no-startup-id brave

# c
bindsym $mod+c              exec --no-startup-id code -n .config/i3/config

# d
bindsym $mod+Shift+d        exec --no-startup-id discord

# e
bindsym $mod+e              exec --no-startup-id thunar

# f
bindsym $mod+f              fullscreen toggle
bindsym $mod+Shift+f        floating toggle

# g
bindsym $mod+g              gaps inner current set $inner_gaps; gaps outer current set $outer_gaps
bindsym $mod+Shift+g        gaps inner current set 0; gaps outer current set 0

# h
bindsym $mod+h              focus left
bindsym $mod+Shift+h        move left 30
bindsym $mod+Ctrl+h         move workspace to output left

# i
bindsym $mod+i              fullscreen disable; floating enable; border none; resize set 1880 1010; move position 20 50

# j
bindsym $mod+j              focus down
bindsym $mod+Shift+j        move down 30
bindsym $mod+Ctrl+j         move workspace to output down

# k
bindsym $mod+k              focus up
bindsym $mod+Shift+k        move up 30
bindsym $mod+Ctrl+k         move workspace to output up

# l
bindsym $mod+l              focus right
bindsym $mod+Shift+l        move right 30
bindsym $mod+Ctrl+l         move workspace to output right

# m

# n

# o

# p
bindsym $mod+p              exec --no-startup-id picom -b
bindsym $mod+Shift+p        exec --no-startup-id killall picom

# q
bindsym $mod+q              [con_id="__focused__" instance="^(?!dropdown_).*$"] kill
bindsym $mod+Shift+q        [con_id="__focused__" instance="^(?!dropdown_).*$"] exec --no-startup-id kill -9 `xdotool getwindowfocus getwindowpid`

# r

# s
bindsym $mod+s              sticky toggle;
bindsym $mod+Shift+s        split toggle

# t

# u

# v
bindsym $mod+v              exec --no-startup-id ~/.config/polybar/hack/scripts/powermenu.sh

# w

# x

# y

# z
bindsym $mod+z exec --no-startup-id bash .config/polybar/hack/launch.sh

# PrintScreen
bindsym Ctrl+Print          exec --no-startup-id flameshot gui -p ~/Pictures/Screenshots
bindsym Print               exec --no-startup-id flameshot full -c -p ~/Pictures/Screenshots

# Alt space
bindsym $alt+space          exec --no-startup-id ~/.config/rofi/bin/launcher_text


# #---Workspace Bindings---# #
bindsym $mod+Ctrl+Right     workspace next
bindsym $mod+Ctrl+Left      workspace prev

bindsym $mod+Shift+slash    kill
bindsym $mod+backslash      workspace back_and_forth

set $ws1 "1"
set $ws2 "2"
set $ws3 "3"
set $ws4 "4"
set $ws5 "5"
set $ws6 "6"
set $ws7 "7"
set $ws8 "8"
set $ws9 "9"
set $ws10 "10"

# Assign Workspaces:
assign [class="discord"] $ws2
assign [class="obs"] $ws7

# Assigning autofloat
for_window [title=".*Emulator.*"] floating enable

# Workspace 1 stuff
for_window [workspace=1] floating enable
for_window [workspace=1] move position 15 45
for_window [workspace=1] border none
for_window [workspace=1] resize set 1890 1020

# Switch to workspace
bindsym $mod+1		workspace $ws1
bindsym $mod+2		workspace $ws2
bindsym $mod+3		workspace $ws3
bindsym $mod+4		workspace $ws4
bindsym $mod+5		workspace $ws5
bindsym $mod+6		workspace $ws6
bindsym $mod+7		workspace $ws7
bindsym $mod+8		workspace $ws8
bindsym $mod+9		workspace $ws9
bindsym $mod+0		workspace $ws10

# Move focused container to workspace
bindsym $mod+Shift+1	move container to workspace $ws1
bindsym $mod+Shift+2	move container to workspace $ws2
bindsym $mod+Shift+3	move container to workspace $ws3
bindsym $mod+Shift+4	move container to workspace $ws4
bindsym $mod+Shift+5	move container to workspace $ws5
bindsym $mod+Shift+6	move container to workspace $ws6
bindsym $mod+Shift+7	move container to workspace $ws7
bindsym $mod+Shift+8	move container to workspace $ws8
bindsym $mod+Shift+9	move container to workspace $ws9
bindsym $mod+Shift+0	move container to workspace $ws10

for_window [window_role="GtkFileChooserDialog"] resize set 800 600
for_window [window_role="GtkFileChooserDialog"] move position center


# #---Function Buttons---# #
bindsym $mod+F1             restart

# #---Arrow Keys---# #
bindsym $mod+Left           focus left
bindsym $mod+Shift+Left     resize shrink width 5 px or 5 ppt
bindsym $mod+Down           focus down
bindsym $mod+Shift+Down     resize shrink height 5 px or 5 ppt
bindsym $mod+Ctrl+Down      move workspace to output up
bindsym $mod+Up             focus up
bindsym $mod+Shift+Up       resize grow height 5 px or 5 ppt
bindsym $mod+Ctrl+Up        move workspace to output down
bindsym $mod+Right          focus right
bindsym $mod+Shift+Right    resize grow width 5 px or 5 ppt

# Pulse Audio controls
bindsym $mod+Prior          exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +10% #increase sound volume
bindsym $mod+Next           exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -10% #decrease sound volume
bindsym $mod+m              exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle # mute sound

# Window borders
client.focused          #4c7899 #285577 #ffffff #2e9ef4   #abb2bf
client.focused_inactive #333333 #5f676a #ffffff #484e50   #5f676a
client.unfocused        #333333 #222222 #888888 #292d2e   #222222
client.urgent           #2f343a #900000 #ffffff #900000   #900000
client.placeholder      #000000 #0c0c0c #ffffff #000000   #0c0c0c
client.background       #ffffff
